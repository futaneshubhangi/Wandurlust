<% layout("/layouts/boilerplate") %>

<style>
  #filters {
    margin-bottom: 2rem;
    display: flex;
    gap: 1.6rem;
    overflow-x: auto;
  }

  .filter {
    text-decoration: none;
    color: #717171;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 0.78rem;
    min-width: 60px;
  }

  .filter i {
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }

  .filter.active {
    color: #000;
    border-bottom: 2px solid #000;
    padding-bottom: 0.4rem;
  }
</style>

<!-- ================= FILTERS ================= -->
<div id="filters">

  <a href="/listings"
     class="filter <%= !selectedCategory ? 'active' : '' %>">
    <i class="fa-solid fa-border-all"></i>
    <span>All</span>
  </a>

  <a href="/listings?category=Trending"
     class="filter <%= selectedCategory === 'Trending' ? 'active' : '' %>">
    <i class="fa-solid fa-fire"></i>
    <span>Trending</span>
  </a>

  <a href="/listings?category=Camping"
     class="filter <%= selectedCategory === 'Camping' ? 'active' : '' %>">
    <i class="fa-solid fa-tent"></i>
    <span>Camping</span>
  </a>

  <a href="/listings?category=Amazing Tools"
     class="filter <%= selectedCategory === 'Amazing Tools' ? 'active' : '' %>">
    <i class="fa-solid fa-screwdriver-wrench"></i>
    <span>Amazing Tools</span>
  </a>

  <a href="/listings?category=Beach"
     class="filter <%= selectedCategory === 'Beach' ? 'active' : '' %>">
    <i class="fa-solid fa-umbrella-beach"></i>
    <span>Beach</span>
  </a>

  <a href="/listings?category=Mountains"
     class="filter <%= selectedCategory === 'Mountains' ? 'active' : '' %>">
    <i class="fa-solid fa-mountain"></i>
    <span>Mountains</span>
  </a>

  <a href="/listings?category=Nature"
     class="filter <%= selectedCategory === 'Nature' ? 'active' : '' %>">
    <i class="fa-solid fa-tree"></i>
    <span>Nature</span>
  </a>

  <a href="/listings?category=City"
     class="filter <%= selectedCategory === 'City' ? 'active' : '' %>">
    <i class="fa-solid fa-city"></i>
    <span>City</span>
  </a>

  <a href="/listings?category=Farms"
     class="filter <%= selectedCategory === 'Farms' ? 'active' : '' %>">
    <i class="fa-solid fa-tractor"></i>
    <span>Farms</span>
  </a>

  <a href="/listings?category=Arctic"
     class="filter <%= selectedCategory === 'Arctic' ? 'active' : '' %>">
    <i class="fa-solid fa-snowflake"></i>
    <span>Arctic</span>
  </a>
  <div class="tax-float">
        <div class="tax-bar">
          <div class="tax-text">
            <p class="tax-title">Display after taxes</p>
            <p class="tax-subtitle">Includes fees, excludes taxes</p>
          </div>

          <label class="airbnb-switch">
            <input type="checkbox" id="taxSwitch">
            <span class="airbnb-slider"></span>
          </label>
        </div>
      </div>
</div>

<!-- ================= LISTINGS ================= -->
<div class="row g-4">
  <% for (let listing of allListings) { %>

    <div class="col-lg-4 col-md-6 col-sm-12">
      <a href="/listings/<%= listing._id %>" class="listing-links">

        <div class="card listing-card index-card">

          <!-- IMAGE -->
          <img
            src="<%= listing.image.url %>"
            class="card-img-top index-img"
            alt="listing image"
          />

          <!-- CONTENT -->
          <div class="card-body index-card-body">
            <p class="index-title"><%= listing.title %></p>

            <!-- IMPORTANT: used by tax switch in navbar -->
            <p class="index-price" data-price="<%= listing.price %>">
              ₹ <%= listing.price.toLocaleString("en-IN") %>
              <span class="price-unit">/ night</span>
            </p>
          </div>

        </div>

      </a>
    </div>

  <% } %>
</div>