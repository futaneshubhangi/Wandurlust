<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6 mb-5 pb-4">

    <form method="post" action="/listings"
          class="needs-validation add-form"
          novalidate enctype="multipart/form-data">

      <h3 class="text-center mb-4">Create a New Listing</h3>

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input 
          name="listing[title]" 
          placeholder="Add catchy title" 
          class="form-control" 
          required>
        <div class="invalid-feedback">
          Please enter a title.
        </div>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea 
          name="listing[description]" 
          class="form-control" 
          required></textarea>
        <div class="invalid-feedback">
          Please enter description.
        </div>
      </div>

      <!-- Category -->
      <div class="mb-3">
        <label class="form-label">Category</label>
        <select 
          name="listing[category]" 
          class="form-select" 
          required>
          <option value="" disabled selected>Select a category</option>
          <option value="Trending">Trending</option>
          <option value="Camping">Camping</option>
          <option value="Beach">Beach</option>
          <option value="Mountains">Mountains</option>
          <option value="Nature">Nature</option>
          <option value="City">City</option>
          <option value="Farms">Farms</option>
          <option value="Arctic">Arctic</option>
          <option value="Amazing Tools">Amazing Tools</option>
        </select>
        <div class="invalid-feedback">
          Please select a category.
        </div>
      </div>

      <!-- Image -->
      <!-- Image -->
<div class="mb-3">
  <label class="form-label">Upload Listing Image</label>
  <input 
    name="listing[image]"
    class="form-control"
    type="file"
    required>
  <div class="invalid-feedback">
    Please upload an image.
  </div>
</div>

      <!-- Price & Country -->
      <div class="row">
        <div class="mb-3 col-md-4">
          <label class="form-label">Price</label>
          <input 
            name="listing[price]" 
            class="form-control" 
            required>
          <div class="invalid-feedback">
            Please enter valid price.
          </div>
        </div>

        <div class="mb-3 col-md-8">
          <label class="form-label">Country</label>
          <input 
            name="listing[country]" 
            class="form-control" 
            required>
          <div class="invalid-feedback">
            Please enter country.
          </div>
        </div>
      </div>

      <!-- Location -->
      <div class="mb-3">
        <label class="form-label">Location</label>
        <input 
          name="listing[location]" 
          class="form-control" 
          required>
        <div class="invalid-feedback">
          Please enter location.
        </div>
      </div>

      <button class="btn btn-dark add-btn w-100">
        Add Listing
      </button>

    </form>

  </div>
</div>