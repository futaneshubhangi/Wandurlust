    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-location-arrow"></i>
    </a>

    <!-- TOGGLER -->
    <button class="navbar-toggler" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup"
      aria-expanded="false"
